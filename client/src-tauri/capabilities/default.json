{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "python3", "cmd": "python3", "args": true },
        { "name": "python3-pyenv", "cmd": "/Users/xiaoxia/.pyenv/versions/3.12.8/bin/python3", "args": true },
        { "name": "python3-conda", "cmd": "/home/hshi/miniconda3/envs/GSdev/bin/python", "args": true }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "python3", "cmd": "python3", "args": true },
        { "name": "python3-pyenv", "cmd": "/Users/xiaoxia/.pyenv/versions/3.12.8/bin/python3", "args": true },
        { "name": "python3-conda", "cmd": "/home/hshi/miniconda3/envs/GSdev/bin/python", "args": true }
      ]
    },
    "fs:default",
    "fs:allow-appdata-read-recursive",
    "fs:allow-appdata-write-recursive",
    "fs:allow-temp-read-recursive",
    "fs:allow-temp-write-recursive"
  ]
}
